# Copy this file to .env and replace every value before starting Compose.
GATEWAY_API_KEY=replace-with-a-local-gateway-key
DEEPSEEK_API_KEY=replace-with-your-deepseek-key
ANTHROPIC_API_KEY=replace-with-your-anthropic-key
GROK_API_KEY=replace-with-your-xai-key
OPEN_AI_API_KEY=replace-with-your-openai-key
# Optional host port; defaults to 8000.
GATEWAY_PORT=8000
